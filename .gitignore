# OS/editor noise
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# Python/tooling caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/

# Never commit secrets or local machine config
.env
.env.*
*.pem
*.key
*.p12
*.mobileprovision
secrets/
private/

# Avoid accidental bulk transcript/database commits
*.sqlite
*.sqlite3
*.db
*.db-wal
*.db-shm
raw-transcripts/
claude-raw/
hermes-raw/
