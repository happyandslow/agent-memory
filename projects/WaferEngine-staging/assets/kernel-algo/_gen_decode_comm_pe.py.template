def pe_grid(ox, oy, cell, n=5, gap=6, fill=PE_F, stroke=PE_S):
    out=[]
    for r in range(n):
        for c in range(n):
            out.append(box(ox+c*(cell+gap),oy+r*(cell+gap),cell,cell,fill,stroke,3,1.0))
    return out
def cc(ox,oy,cell,gap,c,r):
    return (ox+c*(cell+gap)+cell/2, oy+r*(cell+gap)+cell/2)

