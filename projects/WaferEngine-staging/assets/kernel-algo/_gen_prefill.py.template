# serpentine 2x4 block grid
gx0, gy0 = 240, 120
bw, bh = 118, 60
gapx, gapy = 26, 22
# pipeline order for a 2x4 snake: rows even L->R, odd R->L
order = []  # list of (pidx,(bx,by))
for by in range(4):
    xr = range(2) if by % 2 == 0 else range(1, -1, -1)
    for bx in xr:
        order.append((bx, by))
def bxy(bx, by):
    return gx0 + bx*(bw+gapx), gy0 + by*(bh+gapy)
# draw blocks
for p,(bx,by) in enumerate(order):
    x,y = bxy(bx,by)
    hi = (p==0)  # highlight block 0
    s.append(box(x,y,bw,bh,"#cfe4f5" if not hi else "#a9d0ef","#245f96",6,1.6))
    s.append(T(x+bw/2,y+21,f"block p{p}",11.5,"#0d1b26","700"))
    s.append(T(x+bw/2,y+37,f"layers [{p},{p+1})",9,"#2a4a63","500"))
    s.append(T(x+bw/2,y+50,"1 layer (ref)",8.5,"#4a6478","500"))
# serpentine shuttle arrows (blue): consecutive pipeline blocks
def edge_center(bx,by):
    x,y=bxy(bx,by); return x,y,x+bw,y+bh
for i in range(len(order)-1):
    (bx0,by0),(bx1,by1)=order[i],order[i+1]
    x0a,y0a,x0b,y0b=edge_center(bx0,by0)
    x1a,y1a,x1b,y1b=edge_center(bx1,by1)
    if by0==by1:  # horizontal hop
        if bx1>bx0:
            s.append(line(x0b+2,y0a+bh/2,x1a-2,y1a+bh/2,"#2c6fb0","ab",2.4))
        else:
            s.append(line(x0a-2,y0a+bh/2,x1b+2,y1a+bh/2,"#2c6fb0","ab",2.4))
    else:  # south turn
        cx=x0a+bw/2
        s.append(line(cx,y0b+2,cx,y1a-2,"#2c6fb0","ab",2.4))
s.append(T(gx0+bw+gapx/2, gy0+bh+8, "shuttle (P-5)", 9, "#2c6fb0", "700"))

# x_chain in: HT_head -> block0 (green, east)
