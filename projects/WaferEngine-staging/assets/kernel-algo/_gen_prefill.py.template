s.append(T((wb_x+wb_w+bx)/2, by+bh/2-8, "x_chain →", 9.5, "#2e8b57","700"))
s.append(T((wb_x+wb_w+bx)/2, by+bh/2+16, "G-1/G-2/P-6", 8.5, "#2e8b57","500"))

