def node(x,y,w,h,title,sub,fill,stroke,tsz=11):
    out=[box(x,y,w,h,fill,stroke)]
    out.append(T(x+w/2,y+18,title,tsz,"#0d1b26","700"))
    for i,ln in enumerate(sub.split("\n")):
        out.append(T(x+w/2,y+33+i*12,ln,9,"#34434d","500"))
    return "".join(out)

