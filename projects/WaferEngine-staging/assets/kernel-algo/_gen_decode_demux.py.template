#!/usr/bin/env python3
# decode demux.csl algorithm diagram: host X[0] seed ingress, 1xP COLUMN peel + east fan-out.
# Top panel = spatial (demux column + host stream + ready barrier). Bottom = task state machine.
import html
OUT = "/home/lexu/agent-memory/projects/WaferEngine-staging/assets/kernel-algo/qwen3_1p7b-decode.demux.svg"
W, H = 1200, 1120
def esc(s): return html.escape(s)
s = []
s.append(f'<svg xmlns="http://www.w3.org/2000/svg" width="{W}" height="{H}" viewBox="0 0 {W} {H}" font-family="ui-sans-serif,Segoe UI,Helvetica,Arial">')
s.append('<defs>'
  '<marker id="ar" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="#c0392b"/></marker>'
  '<marker id="ab" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="#2c6fb0"/></marker>'
  '<marker id="ag" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="#2e8b57"/></marker>'
  '<marker id="ap" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="#7a3fb0"/></marker>'
  '<marker id="ao" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="#a86a1e"/></marker>'
  '</defs>')
s.append(f'<rect width="{W}" height="{H}" fill="#f7f9fb"/>')
def T(x,y,t,sz=13,f="#12222f",w="600",a="middle"):
    return f'<text x="{x}" y="{y}" font-size="{sz}" font-weight="{w}" fill="{f}" text-anchor="{a}">{esc(t)}</text>'
def box(x,y,w,h,fill,stroke,rx=6,sw=1.6,op=1.0):
    return f'<rect x="{x}" y="{y}" width="{w}" height="{h}" rx="{rx}" fill="{fill}" fill-opacity="{op}" stroke="{stroke}" stroke-width="{sw}"/>'
def line(x1,y1,x2,y2,c,mk,w=2.4,dash=""):
    d=f' stroke-dasharray="{dash}"' if dash else ""
    return f'<line x1="{x1}" y1="{y1}" x2="{x2}" y2="{y2}" stroke="{c}" stroke-width="{w}"{d} marker-end="url(#{mk})"/>'

s.append(T(W/2,30,"decode demux.csl — host X[0] seed ingress: 1xP COLUMN peel + EAST fan-out",19,"#0d1b26","700"))
s.append(T(W/2,50,"Prefill's demux turned on its side: a COLUMN chaining N->S, emitting EAST, carrying a host-PRE-EMBEDDED hidden seed once per round — not token ids every chunk.",11.5,"#4a5b66","500"))
s.append(T(W/2,68,"ref config test_sim_2x2block_kv_varlen.json:  P_BLOCK_SIZE=8 PEs, OWN_B = bsz*dim_per_pe/2 = 8 u32 (= 2 lanes x 8 fp16, packed 2/u32), host sends 8 x 8 = 64 u32 per round",11,"#6a7883","500"))

# ---------------- TOP PANEL: spatial ----------------
s.append(T(60,104,"1  Spatial layout + three moves   (demux = 1 col x P_BLOCK_SIZE rows at fabric_x=2, one col WEST of the HT band)",14,"#0d1b26","700","start"))

# host box
hx, hy = 70, 196
s.append(box(hx, hy, 130, 62, "#f0d9b5", "#a86a1e"))
s.append(T(hx+65, hy+22, "host", 12, "#7a4d10", "700"))
s.append(T(hx+65, hy+38, "X[0] seed, fp16", 9.5, "#7a4d10", "500"))
s.append(T(hx+65, hy+52, "embedded in numpy", 9.5, "#7a4d10", "500"))

# demux column
dx, dy = 300, 196
cw, ch = 210, 62
rows = 8
def ry(r): return dy + r*ch
for r in range(rows):
    last = (r == rows-1)
    s.append(box(dx, ry(r), cw, ch-6, "#e8b06a", "#a86a1e", 5, 1.5))
    s.append(T(dx+cw/2, ry(r)+18, f"demux PE  my_idx={r}" + ("  (last)" if last else ""), 10.5, "#0d1b26", "700"))
    s.append(T(dx+cw/2, ry(r)+33, "peel OWN_B=8 u32", 9, "#12222f", "500"))
    fwd = (rows-1-r)*8
    s.append(T(dx+cw/2, ry(r)+47, (f"forward {fwd} u32 SOUTH" if not last else "no forward (stub)"), 8.5, "#5a3d10", "500"))
s.append(T(dx+cw/2, dy-54, "src_q = iq2 (shared by both fabin DSDs -> G-2 FIFO peel)", 9.5, "#a86a1e", "700"))

# host -> PE0 (Edge.TOP)
s.append(f'<path d="M {hx+130} {hy+31} L {dx-40} {hy+31} L {dx-40} {dy-34} L {dx+cw/2} {dy-34} L {dx+cw/2} {dy-2}" fill="none" stroke="#a86a1e" stroke-width="2.4" marker-end="url(#ao)"/>')
s.append(T(dx-46, hy+22, "in_color, Edge.TOP", 9.5, "#a86a1e", "600", "end"))

# parity chain N->S
for r in range(rows-1):
    par = r % 2
    col = "#c0392b" if par == 0 else "#2c6fb0"
    mk  = "ar" if par == 0 else "ab"
    y1 = ry(r)+ch-6; y2 = ry(r+1)
    s.append(line(dx+cw*0.28, y1+1, dx+cw*0.28, y2-2, col, mk, 2.6))
    s.append(T(dx-6, (y1+y2)/2+4, ("chain_a" if par == 0 else "chain_b") + f"  hop {r}", 8.5, col, "700", "end"))

# HT_head band on the east
bx = dx + cw + 150
s.append(box(bx, dy, 190, rows*ch-6, "#8fbfe0", "#245f96", 6, 1.6, 0.85))
s.append(T(bx+95, dy-14, "HT_head band  (6 cols x 8 rows)", 11, "#245f96", "700"))
for r in range(rows):
    s.append(line(dx+cw+2, ry(r)+26, bx-2, ry(r)+26, "#2e8b57", "ag", 2.0))
    s.append(T(bx+95, ry(r)+44, f"row py={r}: C1 runs EAST, dies at diag col {r//2+2}", 8.5, "#2a4a63", "500"))
s.append(T((dx+cw+bx)/2, dy-34, "out_color = pre_embed_x_color (id 18), RAMP->EAST", 9.5, "#2e8b57", "700"))

# ready barrier (east -> west)
s.append(f'<path d="M {bx} {ry(rows-1)+44} L {dx+cw+4} {ry(rows-1)+44}" fill="none" stroke="#7a3fb0" stroke-width="2.2" stroke-dasharray="5 3" marker-end="url(#ap)"/>')
col_bot = ry(rows)
s.append(T(60, col_bot+10, "ht_ready (id 0), EAST -> WEST, 1 wavelet per row: HT_head's col-0 PE fires it at the end of ITS init(), after painting C1's per-row route. demux init() parks on it and only then activates main.", 10.5, "#7a3fb0", "600", "start"))
s.append(T(60, col_bot+28, "Why: C1's route is painted at RUNTIME by ht_head.csl:264-268, but the demux could otherwise emit at load time. The barrier converts that race into an ordering (bsz=1 configs stall without it).", 10.5, "#7a3fb0", "500", "start"))

# legend
ly = col_bot + 56
s.append(line(60, ly, 88, ly, "#a86a1e", "ao", 2.4))
s.append(T(96, ly+4, "host ingress (P-5 store-and-forward head): the whole P*OWN_B stream lands on PE 0 via Edge.TOP; FIFO order down the column is what makes the peel correct.", 11, "#26333c", "500", "start"))
s.append(line(60, ly+22, 88, ly+22, "#c0392b", "ar", 2.4))
s.append(T(96, ly+26, "parity chain (G-1): peel OWN_B locally, stream FWD_EXTENT = (P-1-my_idx)*OWN_B SOUTH on alternating chain_a (even hop) / chain_b (odd) — no adjacent-router color conflict.", 11, "#26333c", "500", "start"))
s.append(line(60, ly+44, 88, ly+44, "#2e8b57", "ag", 2.4))
s.append(T(96, ly+48, "EAST emit (P-6 p2p): each row drops its OWN_B slice into HT_head row py. Unlike prefill, this is NOT picked up by a multicast — it is a plain run that terminates at one diag PE.", 11, "#26333c", "500", "start"))

# ---------------- BOTTOM PANEL: task state machine ----------------
py0 = ly + 88
s.append(f'<line x1="40" y1="{py0-16}" x2="{W-40}" y2="{py0-16}" stroke="#dce4ea" stroke-width="1.4"/>')
s.append(T(60, py0+4, "2  Task state machine  (same program on every row; my_idx picks the peel offset and FWD_EXTENT)", 14, "#0d1b26", "700", "start"))
def node(x,y,w,h,title,sub,fill,stroke):
    out=[box(x,y,w,h,fill,stroke)]
    out.append(T(x+w/2,y+20,title,12,"#0d1b26","700"))
    for i,ln in enumerate(sub.split("\n")):
        out.append(T(x+w/2,y+37+i*13,ln,9.5,"#34434d","500"))
    return "".join(out)
ny = py0+24; nh = 80; w1 = 240
col_o="#f7e3c8"; s_o="#a86a1e"
col_p="#ebdcf7"; s_p="#7a3fb0"
col_r="#faddd8"; s_r="#c0392b"
col_g="#d7efdb"; s_g="#2e8b57"
xs = [60, 350, 650, 940]
s.append(node(xs[0],ny,w1,nh,"init  (:104)","async @mov32 of 1 ready wavelet\nfrom HT_head col 0\n.activate = main",col_p,s_p))
s.append(node(xs[1],ny,w1,nh,"main  (:109)","@mov32 OWN_B from src_q -> own_buf\nbranch on is_last_pe",col_o,s_o))
s.append(node(xs[2],ny,w1,nh,"forward_and_out  (:127)","2 async ops:\nfwd FWD_EXTENT SOUTH (.unblock)\nemit own_buf EAST (.activate)",col_r,s_r))
s.append(node(xs[3],ny,w1-40,nh,"send_out  (:122)","last PE only:\nno south forward\nemit own_buf EAST",col_g,s_g))
s.append(line(xs[0]+w1, ny+nh/2, xs[1]-2, ny+nh/2, "#5a6b76", "ar", 1.8))
s.append(line(xs[1]+w1, ny+nh/2, xs[2]-2, ny+nh/2, "#5a6b76", "ar", 1.8))
s.append(T((xs[1]+w1+xs[2])/2, ny+nh/2-6, "my_idx < P-1", 9, "#5a6b76", "600"))
s.append(f'<path d="M {xs[1]+w1/2} {ny+nh} L {xs[1]+w1/2} {ny+nh+26} L {xs[3]+(w1-40)/2} {ny+nh+26} L {xs[3]+(w1-40)/2} {ny+nh+2}" fill="none" stroke="#5a6b76" stroke-width="1.8" stroke-dasharray="5 3" marker-end="url(#ar)"/>')
s.append(T((xs[1]+xs[3])/2+60, ny+nh+42, "my_idx == P-1 (is_last_pe)", 9.5, "#5a6b76", "600"))

ny2 = ny + nh + 72
s.append(node(xs[2],ny2,w1,nh-10,"next_cycle  (:136)","join gate for the 2 async ops\nkv_stream_ingress: @block(next_cycle)\n+ @activate(main) for the next round",col_o,s_o))
s.append(f'<path d="M {xs[2]+w1/2} {ny+nh} L {xs[2]+w1/2} {ny2-2}" fill="none" stroke="#5a6b76" stroke-width="1.8" marker-end="url(#ar)"/>')
s.append(f'<path d="M {xs[3]+(w1-40)/2} {ny+nh} L {xs[3]+(w1-40)/2} {ny2+(nh-10)/2} L {xs[2]+w1+2} {ny2+(nh-10)/2}" fill="none" stroke="#5a6b76" stroke-width="1.8" marker-end="url(#ar)"/>')
s.append(f'<path d="M {xs[2]} {ny2+(nh-10)/2} L {xs[1]+w1/2} {ny2+(nh-10)/2} L {xs[1]+w1/2} {ny+nh+2}" fill="none" stroke="#a86a1e" stroke-width="1.8" stroke-dasharray="6 4" marker-end="url(#ao)"/>')
s.append(T(xs[1]+w1/2, ny2+(nh-10)/2+18, "per-round re-arm (KV_TRANSFER=1); KV_TRANSFER=0 -> idle after one shot", 9.5, "#a86a1e", "600"))

s.append(T(60,H-14,"colors/queues:  in_color / chain_color_a / chain_color_b -> src_q=iq2 · forward_oq=oq2 · out_color = pre_embed_x_color(id 18) = oq3 · ht_ready_color(id 0) = ready_iq=iq3.   Count-exactness (OWN_B + FWD_EXTENT) = correctness.",10,"#6a7883","400","start"))
s.append('</svg>')
open(OUT,"w").write("\n".join(s))
print("wrote", OUT, W, H)
