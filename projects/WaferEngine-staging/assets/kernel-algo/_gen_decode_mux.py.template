s.append(f'<path d="M {xs[3]+w1/2} {ny+nh} L {xs[3]+w1/2} {ny+nh+26} L {xs[1]+w1/2} {ny+nh+26} L {xs[1]+w1/2} {ny+nh+2}" fill="none" stroke="#7a3fb0" stroke-width="1.8" stroke-dasharray="5 4" marker-end="url(#ap)"/>')
s.append(T((xs[1]+xs[3])/2+w1/2,ny+nh+41,"PER-STEP loop  (up to n_steps_runtime = N)",9.6,"#7a3fb0","700"))
