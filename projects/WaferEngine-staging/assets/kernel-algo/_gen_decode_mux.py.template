s.append(f'<path d="M {xs[4]+w1/2} {ny+nh} L {xs[4]+w1/2} {ny+nh+62} L {xs[0]+w1/2} {ny+nh+62} L {xs[0]+w1/2} {ny+nh+2}" fill="none" stroke="#a86a1e" stroke-width="1.8" stroke-dasharray="7 4" marker-end="url(#ao)"/>')
s.append(T((xs[0]+xs[4])/2+w1/2,ny+nh+77,"PER-ROUND re-arm (kv_stream_ingress=1): @activate(init) -> park on the next round's header  ·  NUM_ROUNDS = 3",9.6,"#a86a1e","700"))

s.append(T(60,H-32,"Everything rides ONE queue pair (in_q=IQ2 / host_oq=OQ2) in strict FIFO order per round: header, blob x N, TSC burst x 8. No reordering, no credits — backpressure + count-exactness only.",9.8,"#6a7883","400","start"))
s.append(T(60,H-14,"NOTE: launch.py:2251-2260's banner still describes an older W->E cut-through chain emitting full bsz*vocab logits. The shipped code does not do that — one PE, top-K blob.",9.8,"#a8541e","500","start"))
