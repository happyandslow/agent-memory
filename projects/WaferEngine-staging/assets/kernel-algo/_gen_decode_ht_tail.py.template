#!/usr/bin/env python3
# decode ht_tail.csl algorithm diagram: lm_head mesh-GEMV + top-K sampling, looped per token.
# Top panel = spatial (tail band 6x8 ref, vocab-X / dim-Y shard, the 5 acts + the north feedback edge).
# Bottom = task state machine (step loop + round re-arm).
import html
W, H = 1200, 1110
def esc(s): return html.escape(s)
s = []
s.append(f'<svg xmlns="http://www.w3.org/2000/svg" width="{W}" height="{H}" viewBox="0 0 {W} {H}" font-family="ui-sans-serif,Segoe UI,Helvetica,Arial">')
s.append('<defs>'
  '<marker id="ar" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="#c0392b"/></marker>'
  '<marker id="ab" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="#2c6fb0"/></marker>'
  '<marker id="ag" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="#2e8b57"/></marker>'
  '<marker id="ap" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="#7a3fb0"/></marker>'
  '<marker id="ao" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="#a86a1e"/></marker>'
  '</defs>')
s.append(f'<rect width="{W}" height="{H}" fill="#f7f9fb"/>')
def T(x,y,t,sz=13,f="#12222f",w="600",a="middle"):
    return f'<text x="{x}" y="{y}" font-size="{sz}" font-weight="{w}" fill="{f}" text-anchor="{a}">{esc(t)}</text>'
def box(x,y,w,h,fill,stroke,rx=6,sw=1.6,op=1.0):
    return f'<rect x="{x}" y="{y}" width="{w}" height="{h}" rx="{rx}" fill="{fill}" fill-opacity="{op}" stroke="{stroke}" stroke-width="{sw}"/>'
def line(x1,y1,x2,y2,c,mk,w=2.4,dash=""):
    d=f' stroke-dasharray="{dash}"' if dash else ""
    return f'<line x1="{x1}" y1="{y1}" x2="{x2}" y2="{y2}" stroke="{c}" stroke-width="{w}"{d} marker-end="url(#{mk})"/>'

s.append(T(W/2,30,"decode ht_tail.csl - lm_head mesh-GEMV + top-K sampling, looped per generated token",19,"#0d1b26","700"))
s.append(T(W/2,50,"vocab on X, hidden dim on Y. Two orthogonal 2-phase reductions reuse the SAME reduce colors (repaint + fence) - and the sampled token goes NORTH to HT_head, closing the autoregressive loop.",11.5,"#4a5b66","500"))

# ---------------- TOP PANEL: spatial ----------------
s.append(T(60,86,"(1) Spatial layout: tail band 6 x 8 (ref config) + the 5 acts",14,"#0d1b26","700","start"))

gx0=132; cw=118; gap=8; by0=232; bh=38; rows=4
xcols=6
band_w = xcols*(cw+gap)-gap
# lanes above the band
htnorth_y=112; htlabel_y=100
vocabX_arrow_y=150; vocabX_text_y=146; xlocal_y=164; vlab_y=177
zlabel_y=196; zarrow_y=212

# HT_head region (north, receives the sampled token)
hh_x = gx0+band_w-320
s.append(box(hh_x, htlabel_y-24, 320, 26, "#e6d5f2", "#7a3fb0", 6, 1.4))
s.append(T(hh_x+160, htlabel_y-6, "HT_head (embedding) - drains bsz token ids/step", 10.5, "#4a2a63","700"))

# last decode block (east) that ships Z
brx = gx0 + band_w + 22
s.append(box(brx, by0, 86, rows*(bh+8)-8, "#e6d5f2", "#7a3fb0", 6, 1.4))
s.append(T(brx+43, by0+22, "last", 10.5, "#4a2a63","700"))
s.append(T(brx+43, by0+37, "decode", 10.5, "#4a2a63","700"))
s.append(T(brx+43, by0+52, "block", 10.5, "#4a2a63","700"))
s.append(T(brx+43, by0+70, "ships Z + N", 9, "#4a2a63","500"))
s.append(T(brx+43, by0+83, "+ STOP-Z", 9, "#4a2a63","500"))

vlab=[f"vocab [{c*4},{c*4+4})" for c in range(xcols)]
for c in range(xcols):
    x=gx0+c*(cw+gap)
    s.append(T(x+cw/2, xlocal_y, f"x_local={c}", 10, "#245f96","700"))
    s.append(T(x+cw/2, vlab_y, vlab[c], 9, "#245f96","600"))
    for r in range(rows):
        y=by0+r*(bh+8)
        root = (r==rows-1)
        fill = "#8fbfe0"; op = 0.9 if r==0 else 0.5
        if root:
            fill = "#f2d59a"; op=0.95
        s.append(box(x,y,cw,bh,fill,"#245f96",5,1.3,op))
        if r==0:
            s.append(T(x+cw/2,y+15,"lm_head_tile",9,"#12222f","600"))
            s.append(T(x+cw/2,y+27,"[8, 4] f16",8.5,"#2a4a63","500"))
        elif r==1:
            s.append(T(x+cw/2,y+23,"dim shard (Y)",9,"#2a4a63","500"))
        elif not root:
            s.append(T(x+cw/2,y+23,"partials fp32",9,"#2a4a63","500"))
        else:
            if c==4:   lbl="ROOT: SAMPLE"
            elif c==5: lbl="ROOT: S-emit+TSC"
            else:      lbl="ROOT: topK"
            s.append(T(x+cw/2,y+16,lbl,8.5,"#5a3a10","700"))
            s.append(T(x+cw/2,y+29,"y=root_2nd_phase=5",7.5,"#5a3a10","500"))
band_bot = by0+rows*(bh+8)-8

# dim-Y arrow (down the left)
s.append(line(gx0-16, by0, gx0-16, band_bot, "#2c6fb0","ab",2))
s.append(T(gx0-46, (by0+band_bot)/2, "dim (Y)", 9.5, "#2c6fb0","600","middle"))
s.append(T(gx0-46, (by0+band_bot)/2+13, "contract", 8.5, "#2c6fb0","500","middle"))
# vocab-X arrow (top)
s.append(line(gx0, vocabX_arrow_y, gx0+band_w, vocabX_arrow_y, "#245f96","ab",2))
s.append(T(gx0+band_w/2, vocabX_text_y, "vocab (X)", 9.5, "#245f96","700","middle"))

# ACT 1: Z drain west (lane above the band) - orange multicast
zy = zarrow_y
s.append(f'<line x1="{brx}" y1="{by0}" x2="{brx}" y2="{zy}" stroke="#a86a1e" stroke-width="2"/>')
s.append(line(brx-2, zy, gx0+band_w+2, zy, "#a86a1e","ao",2.6))
for c in range(xcols-1):
    xx = gx0+(c+1)*(cw+gap)-gap/2
    s.append(line(xx+2, zy, xx-2, zy, "#a86a1e","ao",2.0))
s.append(T(gx0+band_w/2, zlabel_y, "(1) budget header N, then Z (per step), then STOP-Z  -  E->W multicast (z_drain_color, IQ0)", 10, "#a86a1e","700","middle"))

# ACT 3: Y-reduce (vertical, per column) - blue, into root row
for c in range(xcols):
    x=gx0+c*(cw+gap)+cw/2
    s.append(line(x, by0+(rows-1)*(bh+8)-6, x, band_bot-bh+4, "#2c6fb0","ab",1.8,"5 3"))
s.append(T(gx0, band_bot+18, "(2)/(3) Y 2-phase reduce: RMSNorm sumsq (+bcast) & lm_head dim-contract (no bcast) -> fp32 logits on root row", 10, "#2c6fb0","700","start"))

# ACT 4: X top-K merge (horizontal, along root row) - red
ry = band_bot - bh/2
for c in range(xcols-1):
    x1=gx0+c*(cw+gap)+cw
    x2=gx0+(c+1)*(cw+gap)
    s.append(line(x1+1,ry-4,x2-1,ry-4,"#c0392b","ar",2.2))
    s.append(line(x2-1,ry+8,x1+1,ry+8,"#c0392b","ar",1.5))
s.append(T(gx0, band_bot+38, "(4) X 2-phase MERGE-reduce (top-K lists, not a sum) - SAME reduce colors 1-5, repainted Y->X, fenced by the static tail_xready barrier", 10, "#c0392b","700","start"))
s.append(T(gx0, band_bot+52, "     local top-K = size-K min-heap + SIMD block-max prune (decode runs it PER TOKEN; prefill's O(K*V) argmax passes were ~45% of the budget)", 9.5, "#c0392b","600","start"))

# ACT 5a: NORTH emit (every root col) -> HT_head
for c in range(xcols):
    x=gx0+c*(cw+gap)+cw/2
    s.append(f'<line x1="{x}" y1="{band_bot}" x2="{x+0.01}" y2="{band_bot+4}" stroke="#7a3fb0" stroke-width="0"/>')
nx = gx0+band_w+40
s.append(f'<path d="M {gx0+band_w+8} {band_bot-bh/2} L {nx} {band_bot-bh/2} L {nx} {htlabel_y+8} L {hh_x+320} {htlabel_y+8}" fill="none" stroke="#7a3fb0" stroke-width="2.4" marker-end="url(#ap)"/>')
nly = band_bot + 8
s.append(T(nx+10, nly, "(5a) sampled token", 9.5, "#7a3fb0","700","start"))
s.append(T(nx+10, nly+13, "NORTH -> HT_head", 9.5, "#7a3fb0","700","start"))
s.append(T(nx+10, nly+27, "tok_bcast id 7, OQ7", 9, "#7a3fb0","500","start"))
s.append(T(nx+10, nly+39, "EVERY root col;", 9, "#7a3fb0","500","start"))
s.append(T(nx+10, nly+51, "skipped on last step", 9, "#7a3fb0","500","start"))

# ACT 5b: south emit from east-most root -> mux -> host
ex = gx0+(xcols-1)*(cw+gap)+cw/2
s.append(line(ex, band_bot+56, ex, band_bot+86, "#2e8b57","ag",2.6))
s.append(box(ex-58, band_bot+88, 116, 26, "#bfe0c4","#2e8b57",5,1.4))
s.append(T(ex, band_bot+105, "mux -> host", 10.5, "#12222f","700"))
s.append(T(ex-72, band_bot+105, "(5b) topK val+arg+token+TSC (OQ0)", 9.5,"#2e8b57","700","end"))

# legend
ly = band_bot + 138
leg = [
 ("#a86a1e","ao","P-2 router multicast (z_drain_color, IQ0): carries the per-round budget header N (G-4 + G-13 replicated scalar), the per-step Z, and the in-band STOP-Z sentinel - one channel, three cargoes."),
 ("#2c6fb0","ab","P-1 two-phase all-reduce on Y: RMSNorm sumsq (with bcast) + lm_head dim-contract (no bcast, widened DSD). m=1 -> all-reduce is indicated; Cannon would be wrong here."),
 ("#c0392b","ar","P-1 two-phase reduce on X with a MERGE combiner (tail_topk_mergereduce_x); G-3 repaint + G-8 fence. Runs ONCE PER TOKEN in decode, not once per request."),
 ("#7a3fb0","ap","P-6 p2p north emit: the autoregressive feedback edge decode has and prefill does not. Sampling PE is x=4, south emitter/TSC PE is x=5 - the X-broadcast between them is load-bearing."),
 ("#2e8b57","ag","P-6 p2p south emit: east-most root PE -> mux -> host (logits_south_color, OQ0), every step; the 8-u32 TSC burst piggybacks the same channel on the last step."),
]
for i,(c,mk,txt) in enumerate(leg):
    yy=ly+i*20
    s.append(line(60,yy,86,yy,c,mk,2.2))
    s.append(T(94,yy+4,txt,10,"#26333c","500","start"))

# ---------------- BOTTOM PANEL: task state machine ----------------
py = ly + len(leg)*20 + 26
s.append(f'<line x1="40" y1="{py-14}" x2="{W-40}" y2="{py-14}" stroke="#dce4ea" stroke-width="1.4"/>')
s.append(T(60,py+6,"(2) Task state machine - inner loop per generated token, outer re-arm per round",14,"#0d1b26","700","start"))

def node(x,y,w,h,title,sub,fill,stroke):
    out=[box(x,y,w,h,fill,stroke)]
    out.append(T(x+w/2,y+18,title,11.5,"#0d1b26","700"))
    for i,ln in enumerate(sub.split("\n")):
        out.append(T(x+w/2,y+33+i*12,ln,8.8,"#34434d","500"))
    return "".join(out)

col_o="#f7e3c8"; s_o="#a86a1e"
col_b="#dbeafe"; s_b="#245f96"
col_r="#faddd8"; s_r="#c0392b"
col_g="#d7efdb"; s_g="#2e8b57"

ny=py+22; nh=58; w1=228
xs=[60, 328, 596, 864]
s.append(node(xs[0],ny,w1,nh,"tail_init  :1201","coords + chain ids; paint Y/Z/north/\nsouth/xready routes; PRNG + TSC on\n@activate(tail_main)",col_o,s_o))
s.append(node(xs[1],ny,w1,nh,"tail_main top  :1288","reset done_flag/pred; reseed PRNG;\nread N header off IQ0; re-forward\nN south + north",col_o,s_o))
s.append(node(xs[2],ny,w1,nh,"drain Z  :1320","park on z_recv (IQ0, event-driven)\nTSC start if tail_step==warmup_cycles\nSTOP-Z (Z[0] < -60000) -> break",col_b,s_b))
s.append(node(xs[3],ny,w1,nh,"tail_final_rmsnorm  :423","fp32 sumsq -> Y 2-phase all-reduce\n(+bcast); normalize * W in place",col_b,s_b))
for a in range(3):
    s.append(line(xs[a]+w1,ny+nh/2,xs[a+1]-2,ny+nh/2,"#5a6b76","ar",1.8))

ny2=ny+nh+44
s.append(node(xs[0],ny2,w1,nh,"tail_lm_head_matvec  :405","local @fmachs GEMV ->\npartials[bsz, V_pe] fp32; no comms",col_b,s_b))
s.append(node(xs[1],ny2,w1,nh,"tail_logits_reduce  :726","Y 2-phase reduce, NO bcast; widen\nDSD to bsz*V_pe -> logits on root row",col_b,s_b))
s.append(node(xs[2],ny2,w1,nh,"write_X + xready fence  :1360","repaint reduce colors Y->X;\n1-wavelet 'go' barrier (G-8)\nROOT ROW ONLY",col_r,s_r))
s.append(node(xs[3],ny2,w1,nh,"tail_local_topk  :862","size-K min-heap + @fmaxs block-max\nprune over the V_pe slice; sort DESC",col_r,s_r))
s.append(f'<path d="M {xs[3]+w1/2} {ny+nh} L {xs[3]+w1/2} {ny+nh+20} L {xs[0]+w1/2} {ny+nh+20} L {xs[0]+w1/2} {ny2-2}" fill="none" stroke="#5a6b76" stroke-width="1.8" marker-end="url(#ar)"/>')
for a in range(3):
    s.append(line(xs[a]+w1,ny2+nh/2,xs[a+1]-2,ny2+nh/2,"#5a6b76","ar",1.8))

ny3=ny2+nh+44
s.append(node(xs[0],ny3,w1,nh,"tail_topk_mergereduce_x  :956","X 2-phase reduce; per-hop K-list\nMERGE; bcast global topK to root row",col_r,s_r))
s.append(node(xs[1],ny3,w1,nh,"tail_sample_token  :1085","temp -> softmax -> top-p -> PRNG\n(x==4 only); EOS/pad; STOP_TOK\nthen X-bcast the id to every root col",col_g,s_g))
s.append(node(xs[2],ny3,w1,nh,"write_Y restore + N emit  :1379","repaint X->Y for the next step;\nnorth emit bsz ids (skip last step)",col_g,s_g))
s.append(node(xs[3],ny3,w1,nh,"south emit  :1396","x==HT_WIDTH-1: topK val+arg+token\n(+SOUTH_PAD); TSC burst on last step",col_g,s_g))
s.append(f'<path d="M {xs[3]+w1/2} {ny2+nh} L {xs[3]+w1/2} {ny2+nh+20} L {xs[0]+w1/2} {ny2+nh+20} L {xs[0]+w1/2} {ny3-2}" fill="none" stroke="#5a6b76" stroke-width="1.8" marker-end="url(#ar)"/>')
for a in range(3):
    s.append(line(xs[a]+w1,ny3+nh/2,xs[a+1]-2,ny3+nh/2,"#5a6b76","ar",1.8))

# inner step loop: south emit -> drain Z
s.append(f'<path d="M {xs[3]+w1/2} {ny3+nh} L {xs[3]+w1/2} {ny3+nh+20} L {xs[2]+w1+18} {ny3+nh+20} L {xs[2]+w1+18} {ny+nh+10} L {xs[2]+w1/2} {ny+nh+10} L {xs[2]+w1/2} {ny+nh}" fill="none" stroke="#2c6fb0" stroke-width="1.9" stroke-dasharray="6 4" marker-end="url(#ab)"/>')
s.append(T(xs[2]+w1+26, ny3+nh+16, "inner: while (tail_step < n_steps)  :1313", 9.5, "#2c6fb0","700","start"))
# outer round re-arm: south emit -> tail_main top
s.append(f'<path d="M {xs[3]+w1/2} {ny3+nh} L {xs[3]+w1/2} {ny3+nh+38} L 300 {ny3+nh+38} L 300 {ny+nh+24} L {xs[1]+w1/2} {ny+nh+24} L {xs[1]+w1/2} {ny+nh}" fill="none" stroke="#a86a1e" stroke-width="1.9" stroke-dasharray="6 4" marker-end="url(#ao)"/>')
s.append(T(310, ny3+nh+34, "outer: @activate(tail_main_id) per round  :1422 (kv_stream_ingress=1) - re-park on the next round's N header", 9.5, "#a86a1e","700","start"))

# TSC callout box
tcy = ny3+nh+56
s.append(box(60, tcy, W-120, 40, "#fdf1d6", "#a86a1e", 6, 1.6))
s.append(T(74, tcy+17, "TSC WINDOW (load-bearing): is_tsc_pe = (x=HT_WIDTH-1, y=root_2nd_phase) samples start at tail_step==warmup_cycles (:1316) and end at the last step (:1405).", 10, "#5a3a10","700","start"))
s.append(T(74, tcy+32, "KV injection, the budget-header exchange, tail_init and step 0 are ALL OUTSIDE that span - a decode number from this counter is steady-state per-token only, and hides KV-reload cost.", 10, "#5a3a10","600","start"))

s.append(T(60,H-30,"colors/queues: z_drain=IQ0 (last block's result_color) - reduce 1st/2nd + bcast = ids 1-5 on IQ/OQ 2-6 (shared Y & repainted X) - tail_xready = IQ/OQ 1 - tok_bcast = id 7 OQ7 - logits_south = OQ0.",9.5,"#6a7883","400","start"))
s.append(T(60,H-14,"Count-exactness = correctness (mismatch => silent hang). Fragile triples: north-emit last-step skip vs the host port budget; SOUTH_PAD (:248) vs launch.py:2168; +kv_hdr / +8*num_rounds allowances.",9.5,"#6a7883","400","start"))
s.append('</svg>')
out="/home/lexu/agent-memory/projects/WaferEngine-staging/assets/kernel-algo/qwen3_1p7b-decode.ht_tail.svg"
open(out,"w").write("\n".join(s))
print("ok", W, H, out)
