# ---- grid drawing helper: a small n x n PE block ----
def pe_grid(ox, oy, cell, n=5, gap=6, fill=PE_F, stroke=PE_S):
    out=[]
    for r in range(n):
        for c in range(n):
            x=ox+c*(cell+gap); y=oy+r*(cell+gap)
            out.append(box(x,y,cell,cell,fill,stroke,3,1.0))
    return out
def cc(ox,oy,cell,gap,c,r):  # center of cell (col c,row r)
    return (ox+c*(cell+gap)+cell/2, oy+r*(cell+gap)+cell/2)

