#!/usr/bin/env python3
# mux.csl algorithm diagram: one-shot logits egress. Serialize-through-one-PE collector.
# Top panel = spatial (tail -> mux east-most -> host + TSC relay). Bottom = task state machine.
import html
OUT = "/home/lexu/agent-memory/projects/WaferEngine-staging/assets/kernel-algo/qwen3_1p7b-prefill.mux.svg"
W, H = 1060, 720
def esc(s): return html.escape(s)
s = []
s.append(f'<svg xmlns="http://www.w3.org/2000/svg" width="{W}" height="{H}" viewBox="0 0 {W} {H}" font-family="ui-sans-serif,Segoe UI,Helvetica,Arial">')
s.append('<defs>'
  '<marker id="ar" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="#c0392b"/></marker>'
  '<marker id="ab" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="#2c6fb0"/></marker>'
  '<marker id="ag" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="#2e8b57"/></marker>'
  '<marker id="ap" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="#7a3fb0"/></marker>'
  '<marker id="ao" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="#a86a1e"/></marker>'
  '</defs>')
s.append(f'<rect width="{W}" height="{H}" fill="#f7f9fb"/>')
def T(x,y,t,sz=13,f="#12222f",w="600",a="middle"):
    return f'<text x="{x}" y="{y}" font-size="{sz}" font-weight="{w}" fill="{f}" text-anchor="{a}">{esc(t)}</text>'
def box(x,y,w,h,fill,stroke,rx=6,sw=1.6,op=1.0):
    return f'<rect x="{x}" y="{y}" width="{w}" height="{h}" rx="{rx}" fill="{fill}" fill-opacity="{op}" stroke="{stroke}" stroke-width="{sw}"/>'
def line(x1,y1,x2,y2,c,mk,w=2.4,dash=""):
    d=f' stroke-dasharray="{dash}"' if dash else ""
    return f'<line x1="{x1}" y1="{y1}" x2="{x2}" y2="{y2}" stroke="{c}" stroke-width="{w}"{d} marker-end="url(#{mk})"/>'

s.append(T(W/2,30,"mux.csl — one-shot logits egress (serialize through one PE)",19,"#0d1b26","700"))
s.append(T(W/2,50,"The east-most PE drains the sampled-token / top-K blob from the NORTH and forwards it EAST to the host; all other mux PEs are inert. (2x4 config: 4 PEs)",11.5,"#4a5b66","500"))

# ---------------- TOP PANEL: spatial ----------------
s.append(T(70,86,"1  Spatial layout + collect-and-emit  (mux row = HT_WIDTH_tail x 1, one row SOUTH of HT_tail)",14,"#0d1b26","700","start"))
# HT_tail band across the top, its east-most emitter highlighted
tx0=150; tw,tth=170,42; gap=16
tcols=4
def tx(c): return tx0+c*(tw+gap)
ty=120
for c in range(tcols):
    x=tx(c); active=(c==tcols-1)
    s.append(box(x,ty,tw,tth,"#bfe0c4" if active else "#e8eef2","#2e8b57" if active else "#9fb0bc",6,1.6 if active else 1.2,1.0 if active else 0.7))
    s.append(T(x+tw/2,ty+18,f"HT_tail col {c}",10.5,"#12222f","600"))
    s.append(T(x+tw/2,ty+33,("root-row east-most = emitter" if active else "lm_head / top-K / sample"),8.5,"#2a4a63","500"))
s.append(T(tx0-8,ty+21,"HT_tail",10,"#2e8b57","700","end"))
# mux row below
my=ty+tth+70
for c in range(tcols):
    x=tx(c); active=(c==tcols-1)
    s.append(box(x,my,tw,46,"#e8b06a" if active else "#eceff1","#a86a1e" if active else "#b7c2cb",6,1.6 if active else 1.1,1.0 if active else 0.55))
    if active:
        s.append(T(x+tw/2,my+19,"mux PE (east-most)",11,"#0d1b26","700"))
        s.append(T(x+tw/2,my+35,"is_last_pe=1  (only active)",9,"#5a3d10","600"))
    else:
        s.append(T(x+tw/2,my+27,"inert",10,"#8a97a1","600"))
s.append(T(tx0-8,my+23,"mux",10,"#a86a1e","700","end"))
# tail emitter -> south down east column -> mux east-most (in_color, NORTH->RAMP)
ex=tx(tcols-1)+tw/2
s.append(line(ex,ty+tth,ex,my-2,"#c0392b","ar",2.8))
s.append(T(ex+8,(ty+tth+my)/2-6,"in_color: blob S down east col",9.5,"#c0392b","600","start"))
s.append(T(ex+8,(ty+tth+my)/2+8,"NORTH -> RAMP",8.5,"#c0392b","500","start"))
# mux east-most -> host (EAST)
hostx=tx(tcols-1)+tw+70
s.append(box(hostx,my,80,46,"#f0d9b5","#a86a1e"))
s.append(T(hostx+40,my+27,"host",11,"#7a4d10","700"))
s.append(line(tx(tcols-1)+tw+1,my+23,hostx-2,my+23,"#a86a1e","ao",2.8))
s.append(T((tx(tcols-1)+tw+hostx)/2,my+15,"host_color",8.5,"#a86a1e","700"))
s.append(T((tx(tcols-1)+tw+hostx)/2,my+40,"RAMP->EAST",8,"#a86a1e","500"))

# blob composition annotation
cy=my+92
s.append(box(150,cy,700,54,"#eef4f9","#245f96",6,1.2))
s.append(T(500,cy+20,"one-shot blob = wavelets_per_step u32  (2x4: N=32)",11,"#12222f","700"))
s.append(T(500,cy+38,"TOP_K*bsz packed-f16 values  +  TOP_K*bsz i32 indices  +  bsz sampled token  (+ even-pad)",9.5,"#2a4a63","500"))
# TSC relay note
ty2=cy+72
s.append(line(150,ty2,176,ty2,"#7a3fb0","ap",2.2))
s.append(T(184,ty2+4,"TSC tail-relay: after the blob, drain one 8-u32 TSC burst piggybacked from the north and forward it EAST (reuses in_q / host_oq).",11,"#26333c","500","start"))
s.append(line(150,ty2+22,176,ty2+22,"#c0392b","ar",2.2))
s.append(T(184,ty2+26,"Gate-1 escape #2: no keyed gather of the scattered result — one PE serializes it. Count-exact (N, then 8) both ways.",11,"#26333c","500","start"))

# ---------------- BOTTOM PANEL: task state machine ----------------
py=ty2+64
s.append(f'<line x1="40" y1="{py-16}" x2="{W-40}" y2="{py-16}" stroke="#dce4ea" stroke-width="1.4"/>')
s.append(T(70,py+4,"2  Task state machine  (east-most PE only; drain -> forward -> TSC relay -> re-park)",14,"#0d1b26","700","start"))
def node(x,y,w,h,title,sub,fill,stroke):
    out=[box(x,y,w,h,fill,stroke)]
    out.append(T(x+w/2,y+20,title,12,"#0d1b26","700"))
    for i,ln in enumerate(sub.split("\n")):
        out.append(T(x+w/2,y+37+i*13,ln,9.5,"#34434d","500"))
    return "".join(out)
ny=py+26; nh=58; w1=200
col_b="#dbeafe"; s_b="#245f96"
col_g="#d7efdb"; s_g="#2e8b57"
col_p="#ecdff6"; s_p="#7a3fb0"
col_o="#f7e3c8"; s_o="#a86a1e"
xs=[60,300,540,780]; w1=196
s.append(node(xs[0],ny,w1,nh,"main","drain blob (N u32)\nrecv_dsd -> blob (in_q)",col_b,s_b))
s.append(node(xs[1],ny,w1,nh,"send","forward blob EAST\nblob -> send_dsd (host_oq)",col_g,s_g))
s.append(node(xs[2],ny,w1,nh,"tsc_recv","drain 8-u32 TSC burst\ntsc_recv_dsd (in_q)",col_p,s_p))
s.append(node(xs[3],ny,w1,nh,"tsc_send","forward TSC EAST to host\nthen re-park main",col_o,s_o))
for a,b in [(0,1),(1,2),(2,3)]:
    s.append(line(xs[a]+w1,ny+nh/2,xs[b]-2,ny+nh/2,"#5a6b76","ar",1.8))
# per-request re-park loop tsc_send -> main
s.append(f'<path d="M {xs[3]+w1/2} {ny+nh} L {xs[3]+w1/2} {ny+nh+26} L {xs[0]+w1/2} {ny+nh+26} L {xs[0]+w1/2} {ny+nh+2}" fill="none" stroke="#a86a1e" stroke-width="1.8" stroke-dasharray="6 4" marker-end="url(#ao)"/>')
s.append(T((xs[0]+xs[3])/2+w1/2,ny+nh+42,"per-request re-arm: @activate(main) for the next request",9.5,"#a86a1e","600"))

s.append(T(70,H-14,"colors/queues:  in_color -> in_q=iq2 (NORTH->RAMP) · host_color -> host_oq=oq2 (RAMP->EAST).  Blob + TSC burst reuse the SAME queue pair, drained in FIFO order.  Count mismatch = silent hang.",10,"#6a7883","400","start"))
s.append('</svg>')
open(OUT,"w").write("\n".join(s))
print("wrote", OUT, W, H)
