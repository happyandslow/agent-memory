+# --- worker-side live progress log -------------------------------------------
+# launch.py runs on the appliance worker under SdkLauncher, which buffers stdout
+# until the process exits — so a hang shows no output. These markers are flushed
+# to an absolute progress.log at the worker's invocation cwd; the controller
+# (launch_device.py) pulls it mid-run via launcher.download_artifact("progress.log")
+# (download works mid-run on EPCC; stage() does not). Lets us see compile-vs-run
+# and WHICH receive blocks, live.
+_PROGRESS_PATH = None
+def _prog_init(p):
+    global _PROGRESS_PATH
+    _PROGRESS_PATH = p
+    try:
+        with open(_PROGRESS_PATH, "w") as f:
+            f.write(f"{time.time():.1f} PROGRESS_INIT {p}\n"); f.flush(); os.fsync(f.fileno())
+    except Exception:
+        pass
+def _prog(msg):
+    if _PROGRESS_PATH is None:
+        return
+    try:
+        with open(_PROGRESS_PATH, "a") as f:
+            f.write(f"{time.time():.1f} {msg}\n"); f.flush(); os.fsync(f.fileno())
+    except Exception:
+        pass
