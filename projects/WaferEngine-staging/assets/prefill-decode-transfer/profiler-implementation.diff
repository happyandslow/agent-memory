index 0000000..4be1692
--- /dev/null
+++ b/models/qwen3_1p7b-e2e/src/kv_prof_mux.csl
@@ -0,0 +1,45 @@
+// KV-transfer profiler egress forwarder (one-shot, generic, shared by both
+// halves). The east-most PE of this 1-tall region drains the reporter PE's
+// 4-u32 burst arriving from the block region (RAMP via in_color) and forwards
+// it east to the host stream (host_color -> Edge.RIGHT). All other PEs are
+// inert. This is the 1-PE host-I/O adaptor that lets a deep block PE reach the
+// host, mirroring the logits mux that carries the HT_tail is_tsc_pe burst.
+//
+// Burst layout: prefill = [A, B, done, pad]; decode = [C, done, pad, pad].
+// 4 u32 (even) satisfies the SDK output-port even-wavelet-count constraint.
+
+param is_last_pe: u16;   // 1 on the east-most PE (the only active one)
+param in_color:   u16;   // burst from the block region -> RAMP
+param host_color: u16;   // -> host (RAMP->EAST at the east edge)
+
+const N: i16 = 4;
+
+var blob: [N]u32 = @zeros([N]u32);
+const blob_dsd = @get_dsd(mem1d_dsd, .{ .base_address = &blob, .extent = N });
+
+const in_q:    input_queue  = @get_input_queue(2);
+const host_oq: output_queue = @get_output_queue(2);
+const recv_dsd = @get_dsd(fabin_dsd,  .{ .extent = N, .input_queue  = in_q });
+const send_dsd = @get_dsd(fabout_dsd, .{ .extent = N, .output_queue = host_oq });
+
+const main_id = @get_local_task_id(8);
+const send_id = @get_local_task_id(9);
+
+task main() void {            // drain the burst from the block region
+    @mov32(blob_dsd, recv_dsd, .{ .async = true, .activate = send_id });
+}
+
+task send() void {            // forward it east to the host edge (done)
+    @mov32(send_dsd, blob_dsd, .{ .async = true });
+}
+
+comptime {
+    // Only the east-most PE participates; the rest are inert.
+    if (is_last_pe == 1) {
+        @bind_local_task(main, main_id);
+        @bind_local_task(send, send_id);
+        @activate(main_id);
+        @initialize_queue(in_q,    .{ .color = @get_color(in_color) });
+        @initialize_queue(host_oq, .{ .color = @get_color(host_color) });
+    }
+}
